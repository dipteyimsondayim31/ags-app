# PostgreSQL Veritabanı Bağlantısı
# Yerel geliştirme için (Docker Compose): postgresql://postgres:postgres@localhost:5432/ags_db?schema=public
# Coolify/Canlı ortamda: Coolify tarafından otomatik oluşturulan PostgreSQL bağlantı URL'si buraya yazılacaktır.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ags_db?schema=public"

# NextAuth (Auth.js) Güvenlik Anahtarı
# Güvenli, rastgele 32 karakterli bir değer girilmelidir. (Örn: openssl rand -base64 32 veya project_skills.md'deki script ile üretilen değer)
NEXTAUTH_SECRET="your_nextauth_secret_minimum_32_characters_here"
AUTH_SECRET="your_auth_secret_minimum_32_characters_here"

# Uygulama Canlı URL'si (Yerelde http://localhost:3000, canlıda kendi alan adınız)
NEXTAUTH_URL="http://localhost:3000"

# Admin Giriş Şifresi
# Yerel veritabanı seed edilirken admin kullanıcısı için varsayılan şifre buraya tanımlanır.
ADMIN_PASSWORD="admin_strong_password_here"
